<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@color/white"
    android:layout_margin="16dp">

    <ScrollView android:layout_width="match_parent" android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_kembali"
                    android:id="@+id/btnDismiss"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Konfirmasi Pembayaran"
                    android:textSize="18sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/text_primary"/>

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_kasir"
                    android:background="@drawable/bg_icon_green"
                    android:padding="8dp"/>
            </LinearLayout>

            <!-- Ringkasan Pesanan sesuai Figma -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Ringkasan Pesanan"
                            android:textSize="15sp"
                            android:fontFamily="@font/poppins_semibold"
                            android:textColor="@color/text_primary"/>

                        <TextView
                            android:id="@+id/tvNomorOrder"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="#ORD-0000"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_semibold"
                            android:textColor="@color/green_primary"
                            android:background="@drawable/bg_chip_green"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="3dp"/>
                    </LinearLayout>

                    <!-- Cart items summary -->
                    <LinearLayout
                        android:id="@+id/llOrderItems"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="8dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/card_stroke" android:layout_marginVertical="8dp"/>

                    <!-- Total -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total Bayar"
                            android:textSize="15sp"
                            android:fontFamily="@font/poppins_semibold"
                            android:textColor="@color/text_primary"/>
                        <TextView
                            android:id="@+id/tvTotalBayar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp0"
                            android:textSize="18sp"
                            android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/green_primary"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Metode Pembayaran - RadioGroup sesuai Figma -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Metode Pembayaran"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"/>

            <RadioGroup
                android:id="@+id/rgMetodePembayaran"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <!-- Tunai option -->
                <LinearLayout
                    android:id="@+id/optionTunai"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_payment_option_selected"
                    android:padding="16dp"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_kas"
                        android:background="@drawable/bg_icon_green_light"
                        android:padding="8dp"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tunai"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_primary"/>

                    <RadioButton
                        android:id="@+id/rbTunai"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:buttonTint="@color/green_primary"/>
                </LinearLayout>

                <!-- QRIS option -->
                <LinearLayout
                    android:id="@+id/optionQris"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_payment_option"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_qr_code"
                        android:background="@drawable/bg_icon_green_light"
                        android:padding="8dp"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="QRIS"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_primary"/>

                    <RadioButton
                        android:id="@+id/rbQris"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        android:buttonTint="@color/green_primary"/>
                </LinearLayout>
            </RadioGroup>

            <!-- Konfirmasi Button sesuai Figma -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnKonfirmasi"
                style="@style/BekalMuButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_check_circle"
                android:text="Konfirmasi Bayar"/>
        </LinearLayout>
    </ScrollView>
</com.google.android.material.card.MaterialCardView>
