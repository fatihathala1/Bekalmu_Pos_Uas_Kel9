<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.bekalmu.pos"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="26"
        android:targetSdkVersion="36" />

    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <permission
        android:name="com.bekalmu.pos.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.bekalmu.pos.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:testOnly="true"
        android:theme="@style/Theme.BekalMuPOS" >

        <!-- SPLASH (LAUNCHER) -->
        <activity
            android:name="com.bekalmu.pos.ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.BekalMuPOS.SplashScreen" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- LOGIN -->
        <activity
            android:name="com.bekalmu.pos.ui.login.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- MAIN (Host Bottom Nav) -->
        <activity
            android:name="com.bekalmu.pos.ui.home.MainActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- STRUK / TANDA TERIMA -->
        <activity
            android:name="com.bekalmu.pos.ui.kasir.StrukActivity"
            android:exported="false" />

        <!-- INVENTORI -->
        <activity
            android:name="com.bekalmu.pos.ui.inventori.InventoriActivity"
            android:exported="false"
            android:parentActivityName="com.bekalmu.pos.ui.home.MainActivity" />
        <activity
            android:name="com.bekalmu.pos.ui.inventori.TambahProdukActivity"
            android:exported="false"
            android:parentActivityName="com.bekalmu.pos.ui.inventori.InventoriActivity"
            android:windowSoftInputMode="adjustResize" />

        <!-- TRANSAKSI -->
        <activity
            android:name="com.bekalmu.pos.ui.transaksi.TransaksiActivity"
            android:exported="false"
            android:parentActivityName="com.bekalmu.pos.ui.home.MainActivity" />
        <activity
            android:name="com.bekalmu.pos.ui.transaksi.DetailTransaksiActivity"
            android:exported="false"
            android:parentActivityName="com.bekalmu.pos.ui.transaksi.TransaksiActivity" />

        <!-- KAS -->
        <activity
            android:name="com.bekalmu.pos.ui.kas.KasActivity"
            android:exported="false"
            android:parentActivityName="com.bekalmu.pos.ui.home.MainActivity" />
        <activity
            android:name="com.bekalmu.pos.ui.kas.CatatKasActivity"
            android:exported="false"
            android:parentActivityName="com.bekalmu.pos.ui.kas.KasActivity"
            android:windowSoftInputMode="adjustResize" />

        <!-- LAPORAN (standalone, dari StrukActivity) -->
        <activity
            android:name="com.bekalmu.pos.ui.laporan.LaporanActivity"
            android:exported="false"
            android:parentActivityName="com.bekalmu.pos.ui.home.MainActivity" />

        <!-- PENGATURAN -->
        <activity
            android:name="com.bekalmu.pos.ui.pengaturan.PengaturanActivity"
            android:exported="false"
            android:parentActivityName="com.bekalmu.pos.ui.home.MainActivity" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.bekalmu.pos.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <uses-library
            android:name="androidx.window.extensions"
            android:required="false" />
        <uses-library
            android:name="androidx.window.sidecar"
            android:required="false" />

        <service
            android:name="androidx.room.MultiInstanceInvalidationService"
            android:directBootAware="true"
            android:exported="false" />

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>