<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/card_stroke"
    app:strokeWidth="1dp"
    android:layout_marginVertical="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <ImageView
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_profil"
            android:background="@drawable/bg_icon_green_light"
            android:padding="10dp"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView
                android:id="@+id/tvNamaKasir"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Nama Kasir"
                android:textSize="14sp" android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/text_primary"/>
            <TextView
                android:id="@+id/tvJumlahTransaksi"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0 Transaksi"
                android:textSize="12sp" android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvTotalPendapatan"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Rp0"
            android:textSize="15sp" android:fontFamily="@font/poppins_bold"
            android:textColor="@color/green_primary"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
