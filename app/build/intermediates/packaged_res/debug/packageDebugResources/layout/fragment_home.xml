<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Top Bar sesuai Figma -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_kasir"
            android:tint="@color/background"
            android:background="@drawable/bg_icon_green"
            android:padding="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvCabang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cabang: BKL-JKT01"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aktif"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/green_light" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivNotif"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_notifikasi" />
    </LinearLayout>

    <!-- Menu List Card sesuai Figma -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/BekalMuCard"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="4dp">

            <!-- Point of Sale -->
            <LinearLayout
                android:id="@+id/menuKasir"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_kasir" android:layout_marginEnd="16dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Point of Sale (Kasir)"
                    android:textSize="15sp" android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/text_primary"/>
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" android:tint="@color/text_secondary"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginHorizontal="16dp"/>

            <!-- Transaksi -->
            <LinearLayout
                android:id="@+id/menuTransaksi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_transaksi" android:layout_marginEnd="16dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Transaksi"
                    android:textSize="15sp" android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/text_primary"/>
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" android:tint="@color/text_secondary"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginHorizontal="16dp"/>

            <!-- Inventori -->
            <LinearLayout
                android:id="@+id/menuInventori"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_inventori" android:layout_marginEnd="16dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Inventori"
                    android:textSize="15sp" android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/text_primary"/>
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" android:tint="@color/text_secondary"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginHorizontal="16dp"/>

            <!-- Kas -->
            <LinearLayout
                android:id="@+id/menuKas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_kas" android:layout_marginEnd="16dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Kas Masuk-Keluar"
                    android:textSize="15sp" android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/text_primary"/>
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" android:tint="@color/text_secondary"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginHorizontal="16dp"/>

            <!-- Laporan -->
            <LinearLayout
                android:id="@+id/menuLaporan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_laporan" android:layout_marginEnd="16dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Laporan"
                    android:textSize="15sp" android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/text_primary"/>
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" android:tint="@color/text_secondary"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginHorizontal="16dp"/>

            <!-- Divider sebelum Rekap -->
            <View
                android:id="@+id/dividerRekap"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginHorizontal="16dp"
                android:visibility="gone"/>

            <!-- Rekap Penjualan - KHUSUS OWNER -->
            <LinearLayout
                android:id="@+id/menuRekapPenjualan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground"
                android:visibility="gone">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_laporan" android:layout_marginEnd="16dp"
                    android:tint="@color/green_primary"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Rekap Penjualan Kasir"
                    android:textSize="15sp" android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/text_primary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Owner"
                    android:textSize="10sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_chip_green"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:layout_marginEnd="8dp"/>
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" android:tint="@color/text_secondary"/>
            </LinearLayout>

            <!-- Pengaturan -->
            <LinearLayout
                android:id="@+id/menuPengaturan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_profil" android:layout_marginEnd="16dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Pengaturan"
                    android:textSize="15sp" android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/text_primary"/>
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" android:tint="@color/text_secondary"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
